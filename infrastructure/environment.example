# Application
ENVIRONMENT=production
LOG_LEVEL=INFO
TZ=UTC

# Public endpoint
PUBLIC_DOMAIN=camera.example.com
LETSENCRYPT_EMAIL=admin@example.com

# Port
API_PORT=8100
SSH_PORT=22

# Neon PostgreSQL
DATABASE_URL=
DATABASE_MIGRATION_URL=

# Filesystem
STORAGE_ROOT=/srv/timelapse
# Refuse uploads/exports before storage is exhausted.
STORAGE_HARD_MIN_FREE_BYTES=536870912
STORAGE_SEVERE_MIN_FREE_BYTES=1073741824
RETENTION_WORKER_INTERVAL_SECONDS=3600
RECONCILIATION_WORKER_INTERVAL_SECONDS=3600

# Daily time-lapse video (Asia/Jakarta schedule)
DAILY_TIMELAPSE_ENABLED=true
DAILY_TIMELAPSE_WORKER_INTERVAL_SECONDS=60
DAILY_TIMELAPSE_SEND_HOUR_JAKARTA=0
DAILY_TIMELAPSE_SEND_MINUTE_JAKARTA=10
DAILY_TIMELAPSE_FRAME_RATE=24

# Telegram voice-note playback on the selected camera
VOICE_PLAYBACK_ENABLED=true
VOICE_PLAYBACK_MAX_DURATION_SECONDS=60
VOICE_PLAYBACK_MAX_FILE_BYTES=5242880
VOICE_PLAYBACK_COMMAND_TTL_SECONDS=120
CAMERA_COMMAND_WORKER_INTERVAL_SECONDS=60

# Credentials
CAMERA_TOKEN_PEPPER=replace-with-a-32-byte-random-value
TELEGRAM_BOT_TOKEN=
# Generate 1-256 characters using only A-Z, a-z, 0-9, underscore, and hyphen.
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_USER_ID=
