server {
    listen 80;
    listen [::]:80;

    server_name ${PUBLIC_DOMAIN};
    server_tokens off;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
        default_type text/plain;
        try_files $uri =404;
    }

    location / {
        return 404;
    }
}
